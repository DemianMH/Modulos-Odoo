<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_plan_viaje_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Arial', sans-serif; color: #2C3E50; padding: 10px;">
                        
                        <div class="text-center" style="margin-bottom: 35px; border-bottom: 3px solid #1A365D; padding-bottom: 12px;">
                            <h2 style="color: #1A365D; font-weight: bold; margin-bottom: 4px; text-transform: uppercase;">PLAN DE VIAJE</h2>
                            <h5 style="color: #7F8C8D; font-weight: normal;">Referencia: <span t-field="doc.name"/></h5>
                        </div>

                        <div class="row" style="margin-bottom: 30px;">
                            <div class="col-6">
                                <p><strong>Vendedor:</strong> <span t-field="doc.user_id.name"/></p>
                                <p><strong>Destino:</strong> <span t-field="doc.destination"/></p>
                                <p><strong>Motivo:</strong> <span t-field="doc.motive"/></p>
                            </div>
                            <div class="col-6">
                                <p><strong>Fecha Inicio:</strong> <span t-field="doc.date_start"/></p>
                                <p><strong>Fecha Regreso:</strong> <span t-field="doc.date_end"/></p>
                            </div>
                        </div>

                        <div style="margin-bottom: 25px; page-break-inside: avoid;">
                            <h4 style="color: #1A365D; border-left: 5px solid #1A365D; padding-left: 10px; margin-bottom: 15px;">PARTICIPANTES Y PROGRAMAS</h4>
                            <p><strong>Clientes a Visitar:</strong> <span t-esc="', '.join(map(lambda x: x.name, doc.partner_ids))"/></p>
                            <p><strong>Programas de Lealtad:</strong> <span t-esc="', '.join(map(lambda x: x.name, doc.loyalty_program_ids))"/></p>
                        </div>

                        <div style="margin-bottom: 20px; page-break-inside: avoid;">
                            <h4 style="color: #1A365D; border-left: 5px solid #1A365D; padding-left: 10px; margin-bottom: 10px;">ANÁLISIS PREVIO</h4>
                            <div style="padding: 10px; background-color: #F8F9F9; border: 1px solid #BDC3C7;" t-field="doc.pre_analysis"/>
                        </div>

                        <div style="margin-bottom: 20px; page-break-inside: avoid;">
                            <h4 style="color: #1A365D; border-left: 5px solid #1A365D; padding-left: 10px; margin-bottom: 10px;">CRONOGRAMA</h4>
                            <div style="padding: 10px; background-color: #F8F9F9; border: 1px solid #BDC3C7;" t-field="doc.schedule_notes"/>
                        </div>

                        <div style="margin-bottom: 20px; page-break-inside: avoid;">
                            <h4 style="color: #1A365D; border-left: 5px solid #1A365D; padding-left: 10px; margin-bottom: 10px;">RUTA Y LOGÍSTICA</h4>
                            <div style="padding: 10px; background-color: #F8F9F9; border: 1px solid #BDC3C7;" t-field="doc.route"/>
                        </div>

                        <div style="margin-bottom: 20px; page-break-inside: avoid;">
                            <h4 style="color: #1A365D; border-left: 5px solid #1A365D; padding-left: 10px; margin-bottom: 10px;">ESTRATEGIAS Y ACTIVACIONES</h4>
                            <div style="padding: 10px; background-color: #F8F9F9; border: 1px solid #BDC3C7;" t-field="doc.strategies"/>
                        </div>

                        <div style="margin-bottom: 20px; page-break-inside: avoid;">
                            <h4 style="color: #1A365D; border-left: 5px solid #1A365D; padding-left: 10px; margin-bottom: 10px;">ESTUDIO DE CAMPO</h4>
                            <div style="padding: 10px; background-color: #F8F9F9; border: 1px solid #BDC3C7;" t-field="doc.product_rotation"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>