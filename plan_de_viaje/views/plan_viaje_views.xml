<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_plan_viaje_form" model="ir.ui.view">
        <field name="name">plan.viaje.form</field>
        <field name="model">plan.viaje</field>
        <field name="arch" type="xml">
            <form string="Plan de Viaje">
                <header>
                    <button name="action_submit" string="Enviar a Revisión" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    
                    <button name="action_approve" string="Aprobar" type="object" class="oe_highlight" invisible="state != 'review'" groups="plan_de_viaje.group_plan_viaje_manager"/>
                    <button name="action_reject" string="Rechazar" type="object" class="btn-danger" invisible="state != 'review'" groups="plan_de_viaje.group_plan_viaje_manager"/>
                    
                    <button name="action_done" string="Finalizar Viaje" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approved,done"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" widget="many2one_avatar_user" readonly="state in ['approved', 'rejected', 'done']"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}" readonly="state in ['approved', 'rejected', 'done']"/>
                            <field name="destination" readonly="state in ['approved', 'rejected', 'done']"/>
                            <field name="motive" readonly="state in ['approved', 'rejected', 'done']"/>
                        </group>
                        <group>
                            <field name="date_start" readonly="state in ['approved', 'rejected', 'done']"/>
                            <field name="date_end" readonly="state in ['approved', 'rejected', 'done']"/>
                            <field name="manager_id" invisible="not manager_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Clientes y Ruta" name="clientes_ruta">
                            <group>
                                <field name="partner_ids" widget="many2many_tags" options="{'color_field': 'color'}" readonly="state in ['approved', 'rejected', 'done']"/>
                            </group>
                            <separator string="Logística y Ruta"/>
                            <field name="route" placeholder="Describe la ruta, vuelos, hoteles u orden de visita..." readonly="state in ['approved', 'rejected', 'done']"/>
                        </page>
                        <page string="Análisis y Estrategia" name="analisis_estrategia">
                            <separator string="Análisis Previo"/>
                            <field name="pre_analysis" placeholder="¿Cómo está el cliente actualmente?" readonly="state in ['approved', 'rejected', 'done']"/>
                            
                            <separator string="Programas y Promociones Oficiales"/>
                            <group>
                                <field name="loyalty_program_ids" widget="many2many_tags" placeholder="Selecciona tarjetas de regalo, monederos o descuentos..." readonly="state in ['approved', 'rejected', 'done']"/>
                            </group>
                            
                            <separator string="Estrategias y Notas"/>
                            <field name="strategies" placeholder="Activaciones manuales a proponer o notas adicionales..." readonly="state in ['approved', 'rejected', 'done']"/>
                        </page>
                        <page string="Cronograma" name="cronograma">
                            <field name="schedule_notes" placeholder="Citas, horarios y requisitos de acceso..." readonly="state in ['approved', 'rejected', 'done']"/>
                        </page>
                        <page string="Estudio de Campo" name="estudio_campo">
                            <field name="product_rotation" placeholder="Anotaciones sobre rotación en punto de venta, inventarios..." readonly="state in ['approved', 'rejected', 'done']"/>
                        </page>
                    </notebook>
                </sheet>
                
                <chatter/>
                
            </form>
        </field>
    </record>

    <record id="view_plan_viaje_list" model="ir.ui.view">
        <field name="name">plan.viaje.list</field>
        <field name="model">plan.viaje</field>
        <field name="arch" type="xml">
            <list string="Planes de Viaje" decoration-info="state == 'draft'" decoration-warning="state == 'review'" decoration-success="state == 'approved'" decoration-muted="state == 'done'">
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="destination"/>
                <field name="date_start"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'review'" decoration-success="state == 'approved'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_plan_viaje_search" model="ir.ui.view">
        <field name="name">plan.viaje.search</field>
        <field name="model">plan.viaje</field>
        <field name="arch" type="xml">
            <search string="Buscar Planes">
                <field name="name"/>
                <field name="user_id"/>
                <field name="destination"/>
                <filter string="Mis Viajes" name="mis_viajes" domain="[('user_id', '=', uid)]"/>
                <filter string="En Revisión" name="en_revision" domain="[('state', '=', 'review')]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Ejecutivo" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Estado" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Empresa" name="group_by_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_plan_viaje" model="ir.actions.act_window">
        <field name="name">Planes de Viaje</field>
        <field name="res_model">plan.viaje</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field> </record>

</odoo>