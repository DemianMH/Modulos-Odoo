<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_plan_viaje" model="ir.module.category">
        <field name="name">Plan de Viaje Corporativo</field>
        <field name="description">Niveles de acceso para la planeación y control de viajes</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_plan_viaje_user" model="res.groups">
        <field name="name">Vendedor / Ejecutivo</field>
        <field name="category_id" ref="module_category_plan_viaje"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_plan_viaje_manager" model="res.groups">
        <field name="name">Director / Acceso Completo</field>
        <field name="category_id" ref="module_category_plan_viaje"/>
        <field name="implied_ids" eval="[(4, ref('group_plan_viaje_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <record id="rule_plan_viaje_company" model="ir.rule">
            <field name="name">Planes de Viaje: Multiempresa</field>
            <field name="model_id" ref="model_plan_viaje"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>

        <record id="rule_plan_viaje_user" model="ir.rule">
            <field name="name">Vendedor: Ver solo viajes propios</field>
            <field name="model_id" ref="model_plan_viaje"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_plan_viaje_user'))]"/>
        </record>

        <record id="rule_plan_viaje_manager" model="ir.rule">
            <field name="name">Director: Ver todos los viajes corporativos</field>
            <field name="model_id" ref="model_plan_viaje"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_plan_viaje_manager'))]"/>
        </record>
    </data>
</odoo>