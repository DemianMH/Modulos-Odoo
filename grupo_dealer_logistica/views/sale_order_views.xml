<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_dealer" model="ir.ui.view">
        <field name="name">sale.order.form.dealer</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="x_tipo_cambio" readonly="0" force_save="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list" position="inside">
                <field name="x_porcentaje_importacion" widget="percentage" optional="show"/>
                <field name="x_utilidad_esperada" widget="percentage" optional="show"/>
                <field name="x_tipo_precio" optional="show"/>
                <field name="x_costo_total_pesos" readonly="1" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>