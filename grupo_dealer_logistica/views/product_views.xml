<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_dealer" model="ir.ui.view">
        <field name="name">product.template.form.dealer</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Grupo Dealer" name="grupo_dealer">
                    <group>
                        <field name="x_tipo_articulo"/>
                        <field name="x_moneda_costo"/>
                        <field name="x_extra_costo"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>